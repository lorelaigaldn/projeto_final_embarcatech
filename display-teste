#include <stdio.h>
#include <stdlib.h>
#include "pico/stdlib.h"
#include "hardware/i2c.h"
#include "inc/display.h"
#include "inc/config.h"

ssd1306_t disp; // Estrutura para controlar o display SSD1306

/**
 * @brief Configura a comunicação I2C e inicializa o display SSD1306.
 *
 * Esta função inicializa a interface I2C1 com frequência de 400 kHz e configura
 * os pinos GPIO para comunicação I2C. Também inicializa o display OLED SSD1306
 * com resolução de 128x64 pixels e endereço I2C 0x3C.
 *
 * O display é limpo e uma mensagem inicial é exibida.
 */
void setup_display()
{
    i2c_init(i2c1, 600000);                    // Inicializa I2C1 com 600 kHz
    gpio_set_function(SDA_PIN, GPIO_FUNC_I2C); // Configura pino SDA para I2C
    gpio_set_function(SCL_PIN, GPIO_FUNC_I2C); // Configura pino SCL para I2C
    gpio_pull_up(SDA_PIN);                     // Ativa pull-up no SDA
    gpio_pull_up(SCL_PIN);                     // Ativa pull-up no SCL

    disp.external_vcc = false;                 // Usa alimentação interna do display
    ssd1306_init(&disp, 128, 64, 0x3C, i2c1);  // Inicializa o display OLED

    ssd1306_clear(&disp);

    // Mensagem inicial no display
    ssd1306_draw_string(&disp, 5, 10, 2, "SilentPico");
    ssd1306_draw_string(&disp, 5, 30, 1, "Oi, sou RP2040");

    ssd1306_show(&disp);
}

/**
 * @brief Atualiza o display com o nível de decibéis (dB) do microfone.
 *
 * @param micdata Ponteiro para estrutura que contém o valor de dB.
 *
 * A função só atualiza o display quando o valor de dB muda,
 * evitando atualizações desnecessárias.
 */
void update_display_db_value(micdata_t *micdata)
{
    char buffer[16];                 // Buffer para texto do display
    static uint16_t last_db = 0;    // Guarda último valor exibido

    // Só atualiza se o valor de dB mudou
    if (micdata->dB != last_db)
    {
        sprintf(buffer, "dB: %d.%01d\n",
                micdata->dB / 10,
                abs(micdata->dB % 10));

        // Limpa área onde o texto aparece
        ssd1306_clear_area(&disp, 0, 0, 128, 28);

        // Desenha novo valor no display
        ssd1306_draw_string(&disp, 0, 0, 2, buffer);

        // Atualiza tela
        ssd1306_show(&disp);

        // Atualiza controle do último valor
        last_db = micdata->dB;
    }
}
